# Copy this file to .env and fill in values locally.
# Never commit .env.

# Copernicus Climate Data Store / ECMWF Data Stores.
# Get these from your CDS/EWDS profile and dataset "Show API request" pages.
# CDS profile: https://cds.climate.copernicus.eu/profile
# EWDS API docs: https://confluence.ecmwf.int/display/CEMS/EWDS+API
CDS_API_URL=https://cds.climate.copernicus.eu/api
CDS_API_KEY=
EWDS_API_URL=https://ewds.climate.copernicus.eu/api
EWDS_API_KEY=

# Optional Copernicus Data Space Ecosystem credentials.
# Useful later for authenticated CDSE/STAC/OData product access.
# Docs: https://documentation.dataspace.copernicus.eu/
CDSE_USERNAME=
CDSE_PASSWORD=
CDSE_CLIENT_ID=cdse-public

# NASA Earthdata / CDDIS for GNSS, RINEX, IGS products.
# Earthdata login: https://urs.earthdata.nasa.gov/
# CDDIS archive access: https://www.earthdata.nasa.gov/centers/cddis-daac/archive-access
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
CDDIS_BASE_URL=https://cddis.nasa.gov/archive

# FAO / supplemental data sources.
# Leave blank until we wire source-specific clients.
FAO_WAPOR_API_KEY=

# Local dataloader defaults.
DATALOADER_OUTPUT_DIR=horizon/nrsm/data/generated
DATALOADER_RAW_DIR=horizon/nrsm/data/raw
DATALOADER_START_DATE=2020-01-01
DATALOADER_END_DATE=2020-01-31
DATALOADER_SCENARIOS=3
